<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fixflow.controller.LoginController">
    <children>
        <Label text="FixFlow Login">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <VBox maxWidth="250.0" spacing="10.0">
            <children>
                <Label text="Usuario:" />
                <TextField fx:id="txtUser" promptText="Introduce tu usuario" />
                <Label text="Contraseña:" />
                <PasswordField fx:id="txtPass" promptText="Introduce tu contraseña" />
            </children>
        </VBox>
        <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#handleLogin" prefWidth="100.0" text="Entrar" />
    </children>
</VBox>
