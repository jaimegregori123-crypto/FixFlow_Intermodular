<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fixflow.controller.MainViewController">
    <children>
        <Label layoutX="102.0" layoutY="54.0">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
      <BorderPane fx:id="rootPane">
         <left>
            <VBox alignment="TOP_CENTER" spacing="15.0" BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="btnMenuActivos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onActivosClick" text="Activos" />
                  <Button fx:id="btnMenuUsuarios" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onUsuariosClick" text="Usuarios" />
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onIncidenciasClick" text="Incidencias" />
                  <Button mnemonicParsing="false" onAction="#onIntervencionesClick" prefHeight="27.0" prefWidth="95.0" text="Intervenciones" />
                  <Button layoutX="20.0" layoutY="132.0" mnemonicParsing="false" onAction="#onIntervencionesClick" prefHeight="27.0" prefWidth="95.0" text="Cerrar Sesion" />
               </children>
               <padding>
                  <Insets left="15.0" right="15.0" />
               </padding>
            </VBox>
         </left>
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </BorderPane>
    </children>
</AnchorPane>
