<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-padding: 15;">

    <TableView fx:id="tablaIntervencionesView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="75.0" text="ID" />
            <TableColumn prefWidth="200.0" text="Observaciones" />
            <TableColumn prefWidth="150.0" text="Fecha" />
            <TableColumn prefWidth="150.0" text="Incidencia" />
            <TableColumn prefWidth="120.0" text="Técnico" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <VBox alignment="CENTER" spacing="10.0">
        <HBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="txtIntervencionDesc" promptText="Descripción técnica" />
            <TextField fx:id="txtIntervencionIncidencia" promptText="ID Incidencia" />
            <TextField fx:id="txtIntervencionUsuario" promptText="ID Usuario" />
            <Button fx:id="btnAgregarIntervencion" mnemonicParsing="false" text="Agregar Intervención" />
        </HBox>
    </VBox>

</VBox>