<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CONTROLLER_NAME"
      style="-fx-padding: 15;">

    <TableView fx:id="tablaUsuariosView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="90.0" text="ID" />
            <TableColumn fx:id="colUser" prefWidth="100.0" text="Usuario" />
            <TableColumn fx:id="colRol" prefWidth="100.0" text="Rol" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <VBox alignment="CENTER" spacing="10.0">
        <HBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="txtUserNombre" promptText="Nombre" />
            <ComboBox fx:id="txtUserRol" prefWidth="150.0" />
            <PasswordField fx:id="txtUserPassword" promptText="Contraseña" />
            <Button fx:id="btnAgregarUsuario" mnemonicParsing="false" text="Agregar Usuario" />
        </HBox>
    </VBox>

</VBox>
