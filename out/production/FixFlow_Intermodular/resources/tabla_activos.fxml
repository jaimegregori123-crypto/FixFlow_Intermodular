<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CONTROLLER_NAME">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>
                <TableView fx:id="tablaActivosView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="90.0" text="ID" />
                        <TableColumn prefWidth="100.0" text="Nombre" />
                        <TableColumn prefWidth="100.0" text="Ubicación" />
                        <TableColumn prefWidth="100.0" text="Estado" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <TextField fx:id="txtNombre" promptText="Nombre" />
                                <TextField fx:id="txtUbicacion" promptText="Ubicación" />
                                <TextField fx:id="txtEstado" promptText="Estado" />
                            </children>
                        </HBox>
                        <Button fx:id="btnAgregarActivo" mnemonicParsing="false" text="Agregar Activo" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
