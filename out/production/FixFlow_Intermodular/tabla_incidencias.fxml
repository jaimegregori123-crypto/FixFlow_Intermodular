<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CONTROLLER_NAME"
      style="-fx-padding: 15;">

    <TableView fx:id="tablaIncidenciasView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="75.0" text="ID" />
            <TableColumn prefWidth="75.0" text="Titulo" />
            <TableColumn prefWidth="75.0" text="Descripción" />
            <TableColumn prefWidth="75.0" text="Prioridad" />
            <TableColumn prefWidth="75.0" text="Fecha" />
            <TableColumn prefWidth="75.0" text="Activo" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <VBox alignment="CENTER" spacing="10.0">
        <HBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="txtIncidenciaTitulo" promptText="Título" />
            <TextField fx:id="txtIncidenciaDesc" promptText="Descripción" />
            <ComboBox fx:id="comboPrioridad" prefWidth="150.0" />
            <TextField fx:id="txtIncidenciaActivo" promptText="ID Activo" />
        </HBox>
        <HBox alignment="CENTER" spacing="10.0">
            <Button fx:id="btnAgregarIncidencia" mnemonicParsing="false" text="Agregar Incidencia" />
            <Button mnemonicParsing="false" text="Resolver" />
        </HBox>
    </VBox>

</VBox>
