<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CONTROLLER_NAME"
      style="-fx-padding: 15;">

    <TableView fx:id="tablaIncidenciasView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="50.0" text="ID" />
            <TableColumn prefWidth="120.0" text="Titulo" />
            <TableColumn prefWidth="150.0" text="Descripción" />
            <TableColumn prefWidth="80.0" text="Prioridad" />
            <TableColumn prefWidth="90.0" text="Fecha" />
            <TableColumn prefWidth="60.0" text="Activo" />
            <TableColumn prefWidth="80.0" text="Estado" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <VBox alignment="CENTER" spacing="10.0">
        <HBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="txtIncidenciaTitulo" promptText="Título" />
            <TextField fx:id="txtIncidenciaDesc" promptText="Descripción" />
            <ComboBox fx:id="comboPrioridad" promptText="Prioridad" prefWidth="150.0" />
            <TextField fx:id="txtIncidenciaActivo" promptText="ID Activo" />
        </HBox>
        <HBox alignment="CENTER" spacing="10.0">
            <Button fx:id="btnAgregarIncidencia" mnemonicParsing="false" text="Agregar Incidencia" />
            <Button fx:id="btnResolver" mnemonicParsing="false" text="✔  Resolver Incidencia" />
            <Button fx:id="btnEliminarIncidencia" mnemonicParsing="false" text="🗑  Eliminar Seleccionado" />
        </HBox>
    </VBox>

</VBox>
