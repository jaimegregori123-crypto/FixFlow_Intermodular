<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CONTROLLER_NAME"
      style="-fx-padding: 15;">

    <TableView fx:id="tablaActivosView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="90.0" text="ID" />
            <TableColumn prefWidth="100.0" text="Nombre" />
            <TableColumn prefWidth="100.0" text="Ubicación" />
            <TableColumn prefWidth="100.0" text="Estado" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <VBox alignment="CENTER" spacing="10.0">
        <HBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="txtNombre" promptText="Nombre" />
            <TextField fx:id="txtUbicacion" promptText="Ubicación" />
            <TextField fx:id="txtEstado" promptText="Estado" />
        </HBox>
        <Button fx:id="btnAgregarActivo" mnemonicParsing="false" text="Agregar Activo" />
    </VBox>

</VBox>
